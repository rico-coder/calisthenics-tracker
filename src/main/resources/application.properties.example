spring.application.name=calisthenics-tracker
spring.datasource.url=jdbc:postgresql://localhost:5432/calisthenics-tracker
spring.datasource.username=devuser
spring.datasource.password=CHANGE_ME
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.open-in-view=false
app.admin.username=YOUR_USERNAME
app.admin.password=CHANGE_ME
app.jwt.secret=CHANGE_ME
app.jwt.expiration=86400000